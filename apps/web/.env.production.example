# Copy this to .env.production (gitignored) before a production `bun run build`.
#
# Absolute site origin for canonical / Open Graph / sitemap URLs — read at build
# time by vite.config.ts (loadEnv) and scripts/prerender.ts. A production build
# fails fast if this is empty (see vite-plugin-seo-head.ts). Not secret:
# VITE_-prefixed vars are inlined into the client bundle. Moving hosts/domains
# (e.g. the Cloudflare cutover) is a one-line change here.
VITE_SITE_URL=https://morse-ml.netlify.app

# --- Supabase (optional accounts / leaderboard / QRZ badge) ------------------
# Client-side Supabase connection. BOTH are safe to expose: VITE_-prefixed vars
# ship in the browser bundle by design, and the publishable key is meant to be
# public — Row-Level Security (see supabase/migrations) is what protects data,
# not key secrecy.
#
# For LOCAL DEV put these in .env.local (gitignored) instead of here.
# For PROD prefer setting them in the host's env UI (Netlify → Environment
# variables) over committing real values to this tracked file.
#
# The SECRET key (sb_secret_…) is NEVER set here and never VITE_-prefixed — it
# would leak into every browser. It lives only in the verify Edge Function's
# secret store (slice 5: `supabase secrets set`).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
