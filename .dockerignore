# Build-context-root .dockerignore — this is the ONLY one Docker reads
# during builds. Dockerfile lives at cw-ml/model/Dockerfile but build context
# is morse/ (set by cw-ml/model/build-docker.sh) so morse-audio/ is reachable
# as a sibling. Don't add child .dockerignore files — Docker won't honor them
# and they create maintenance traps.
**/.env
**/.env.*
**/node_modules/
**/.venv/
**/runs/
**/__pycache__/
**/*.pyc
**/*.npz
**/*.wav
**/*.pt
# Allow the baked-in starting-point checkpoint into the cw-model image.
# Keep in sync with cw-ml/model/checkpoints/.gitignore allowlist.
!cw-ml/model/checkpoints/best.pt
!cw-ml/model/checkpoints/base.pt
!cw-ml/model/checkpoints/best.yaml
**/*.onnx
**/.DS_Store
